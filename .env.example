# Binance API
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Bybit API
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# MEXC API (메이커 수수료 0%, 소액 아비트라지 최적)
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here

# Gate.io API (알트코인 종류 최다, 스프레드 큼)
GATEIO_API_KEY=your_gateio_api_key_here
GATEIO_API_SECRET=your_gateio_api_secret_here

# 봇 설정
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 리스크 설정
MAX_POSITION_USDT=100        # 코인 1개당 최대 포지션 (USDT)
MAX_TOTAL_USDT=500           # 전체 최대 투자금 (USDT)
MIN_FUNDING_RATE=0.01        # 최소 수익성 펀딩피 (%)
MIN_ARBITRAGE_SPREAD=0.3     # 최소 차익거래 스프레드 (%)
